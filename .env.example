# =============================================================================
# AI Business Decision Copilot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# --- Google Gemini API ---
GOOGLE_API_KEY=your_google_api_key_here

# --- JWT Authentication ---
JWT_SECRET_KEY=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
DATABASE_URL=sqlite:///./copilot.db

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# --- Application ---
APP_NAME=AI Business Decision Copilot
APP_VERSION=1.0.0
DEBUG=true

# --- Frontend ---
BACKEND_URL=http://localhost:8000
STREAMLIT_PORT=8501
